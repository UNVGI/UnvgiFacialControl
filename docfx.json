{
  "metadata": [
    {
      "src": [
        {
          "src": "FacialControl",
          "files": [
            "Hidano.FacialControl.Domain.csproj",
            "Hidano.FacialControl.Application.csproj",
            "Hidano.FacialControl.Adapters.csproj",
            "Hidano.FacialControl.Editor.csproj"
          ]
        }
      ],
      "dest": "api",
      "filter": "docfx-filter.yml",
      "properties": {
        "TargetFramework": "netstandard2.1"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "toc.yml"
        ]
      },
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "manual/**.md",
          "manual/toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "manual/images/**"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appTitle": "FacialControl",
      "_appName": "FacialControl",
      "_appFooter": "FacialControl - MIT License",
      "_enableSearch": true
    },
    "template": [
      "default",
      "modern"
    ]
  }
}
